{
  "version": 2,
  "buildCommand": "pnpm install && cd artifacts/madhur-asha && pnpm run build",
  "outputDirectory": "artifacts/madhur-asha/dist",
  "framework": "vite",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}