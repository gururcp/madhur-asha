{
  "version": 2,
  "buildCommand": "cd artifacts/madhur-asha && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/madhur-asha/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "@api_url"
  }
}